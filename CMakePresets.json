{
    "version": 3,
    "configurePresets": [
        {
            "name": "windows-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "installDir": "${sourceDir}/install/${presetName}",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "x64-debug",
            "displayName": "x64 Debug",
            "inherits": "windows-base",
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CYNLR_USE_GTEST":  "OFF"
            }
        },
        {
            "name": "x64-release",
            "displayName": "x64 Release",
          "inherits": "x64-debug",

          "cacheVariables": {
            "CMAKE_BUILD_TYPE": "Release"

          }
          
        },
        {
            "name": "x64-release-perf",
            "displayName": "x64 Release  [PERF]",
            "inherits": "x64-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CYNLR_PERF":       "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name":             "debug-all",
            "displayName":      "Debug — all targets",
            "configurePreset":  "x64-debug"
        },
        {
            "name":             "release-all",
            "displayName":      "Release — all targets",
            "configurePreset":  "x64-release"
        },
        {
            "name":             "release-perf-all",
            "displayName":      "Release [PERF] — all targets",
            "configurePreset":  "x64-release-perf"
        }
    ],
    "testPresets": [
        {
            "name":            "test-debug",
            "displayName":     "Run tests  (Debug)",
            "configurePreset": "x64-debug",
            "output":          { "outputOnFailure": true }
        },
        {
            "name":            "test-release",
            "displayName":     "Run tests  (Release)",
            "configurePreset": "x64-release",
            "output":          { "outputOnFailure": true }
        }
    ]
}
